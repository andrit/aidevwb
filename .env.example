# ╔══════════════════════════════════════════════════════════════╗
# ║  AI Dev Workbench — Environment Configuration               ║
# ║  Copy to .env and fill in your keys                         ║
# ║  cp .env.example .env && nano .env                          ║
# ╚══════════════════════════════════════════════════════════════╝

# ── LLM: Anthropic Claude (direct, no proxy) ─────────────────
ANTHROPIC_API_KEY=sk-ant-...your-anthropic-key

# ── Embeddings: local Ollama (default — free, no account required) ──
# Ollama runs inside Docker and downloads mxbai-embed-large (~670MB) on first start.
# The model is cached in a Docker volume — only downloaded once.
EMBEDDING_BASE_URL=http://ollama:11434/v1
EMBEDDING_API_KEY=ollama
EMBEDDING_MODEL=mxbai-embed-large
EMBEDDING_DIMENSIONS=1024

# ── To switch to Voyage AI (free tier, higher quality) ───────────
# Free account at https://www.voyageai.com — 50M tokens/month, no credit card needed.
# EMBEDDING_BASE_URL=https://api.voyageai.com/v1
# EMBEDDING_API_KEY=va-your-key-here
# EMBEDDING_MODEL=voyage-3
# EMBEDDING_DIMENSIONS=1024

# ── OpenRouter (optional, requires paid credits) ─────────────────
OPENROUTER_API_KEY=

# ── LLM Model Selection ──────────────────────────────────────
CLAUDE_MODEL=claude-sonnet-4-20250514

# ── Supabase (self-hosted, auto-configured) ───────────────────
POSTGRES_PASSWORD=your-super-secret-postgres-password
JWT_SECRET=your-super-secret-jwt-token-at-least-32-chars
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU
SUPABASE_URL=http://supabase-kong:8000
SUPABASE_PUBLIC_URL=http://localhost:8000

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Observability ─────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_SERVICE_NAME=ai-dev-workbench

# ── Workbench Settings ────────────────────────────────────────
# Port for the MCP/API orchestration server
API_PORT=3100
# Enable RAG features (set to false for pure dev workbench)
ENABLE_RAG=true

# ── Active Project ────────────────────────────────────────────
# WORKBENCH_PROJECT: the project whose database MCP tools write to.
# Defaults to "workbench-source" — the workbench's own development history.
# Switch projects by changing both values and restarting claude-code:
#   WORKBENCH_PROJECT=myapp PROJECT_DIR=~/code/myapp docker compose up -d claude-code
WORKBENCH_PROJECT=workbench-source

# PROJECT_DIR: host path mounted as /workspace inside claude-code.
# Default (.) = the workbench source directory itself.
# Change to your project's directory when switching projects.
PROJECT_DIR=.
