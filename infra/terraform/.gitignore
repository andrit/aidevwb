# Terraform state (contains secrets, never commit)
*.tfstate
*.tfstate.backup
*.tfstate.lock.info

# Variables files (contain API keys)
terraform.tfvars
*.auto.tfvars

# Provider plugins (large, downloaded on init)
.terraform/
.terraform.lock.hcl

# Crash logs
crash.log
crash.*.log

# Plan output files
*.tfplan
